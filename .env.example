# Environment
NODE_ENV=development

# Supabase
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Mapbox
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# App URLs (for auth callbacks)
VITE_APP_URL=http://localhost:5173
VITE_SUPABASE_REDIRECT_URL=http://localhost:5173/auth/callback

# PostHog Analytics
VITE_POSTHOG_KEY=your_posthog_project_api_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# Feature Flags
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_ANALYTICS=false

# Rate Limiting
VITE_API_RATE_LIMIT=100
VITE_API_RATE_WINDOW_MS=60000

# Testing
VITE_TEST_USER_EMAIL=test@example.com
VITE_TEST_USER_PASSWORD=testpassword123

# App Version
VITE_APP_VERSION=1.0.0
